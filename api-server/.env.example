# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
REDIS_URL=your_redis_url
ECS_CLUSTER=your_ecs_cluster_arn
ECS_TASK=your_ecs_task_arn

# VPC Configuration
VPC_SUBNET_1=subnet-xxx
VPC_SUBNET_2=subnet-xxx
VPC_SUBNET_3=subnet-xxx
SECURITY_GROUP=sg-xxx

# S3 Configuration
S3_BUCKET_NAME=your-bucket-name
S3_BASE_PATH=https://your-bucket.s3.region.amazonaws.com/__outputs

# Server Ports
API_PORT=9000
PROXY_PORT=8000

# Auth & Security
JWT_SECRET=generate-a-random-64-byte-hex-secret
COOKIE_SECRET=generate-a-different-random-secret
COOKIE_DOMAIN=
FRONTEND_ORIGIN=http://localhost:3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/
MONGODB_DB=exonium

# Internal build-server callback
INTERNAL_API_TOKEN=generate-a-random-32-byte-hex-token
INTERNAL_API_URL=http://localhost:9000
